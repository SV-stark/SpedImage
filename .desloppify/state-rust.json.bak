    "review::.::holistic::logic_clarity::crop_pipeline_layout_binding_mismatch::c2db977d": {
      "id": "review::.::holistic::logic_clarity::crop_pipeline_layout_binding_mismatch::c2db977d",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "CROP_SHADER declares a uniform binding but the crop_pipeline_layout has no bind group layouts",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "src/gpu_renderer.rs"
        ],
        "evidence": [
          "CROP_SHADER (line 171): `@group(0) @binding(0) var<uniform> crop: CropUniforms;` \u00e2\u20ac\u201d declares a uniform requirement.",
          "crop_pipeline_layout (line 431-435): `bind_group_layouts: &[]` \u00e2\u20ac\u201d no layouts registered.",
          "This means the shader declares a binding that the pipeline layout doesn't satisfy \u00e2\u20ac\u201d a structural lie that wgpu may catch at runtime or silently allow (as the fragment shader never reads the value)."
        ],
        "suggestion": "Either register a CropUniforms bind group layout in the crop_pipeline_layout (and actually pass the crop rect), or remove the uniform declaration from CROP_SHADER and use a push constant or pass data via vertex buffers.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-07T17:19:29+00:00",
      "last_seen": "2026-03-07T17:19:29+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "rust",
      "suppressed": false,
