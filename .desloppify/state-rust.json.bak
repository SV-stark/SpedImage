      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "SpedImageApp is a 23-field god-struct mixing 6 unrelated concerns",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "src/app/state.rs"
        ],
        "evidence": [
          "Fields span: window/renderer handles, image animation state (current_frame_delays, current_frame_idx), event channel (event_tx, event_rx, event_proxy), navigation (prefetch_cache, held_navigation_key, last_advance_time), thumbnail loading concurrency (thumb_active, thumb_paths), and slideshow timing.",
