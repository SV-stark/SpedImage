    "review::.::holistic::initialization_coupling::hardcoded_font_path_construction::b4617450": {
      "id": "review::.::holistic::initialization_coupling::hardcoded_font_path_construction::b4617450",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Renderer::new hardcodes C:\\Windows\\Fonts\\segoeui.ttf as an absolute path read at construction time",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "src/gpu_renderer.rs"
        ],
        "evidence": [
          "Line 473: `std::fs::read(\"C:\\\\Windows\\\\Fonts\\\\segoeui.ttf\")` \u00e2\u20ac\u201d absolute OS-specific path baked into constructor.",
          "Fails silently on non-Windows or Windows Server without Segoe UI, falling back to embedded font with no diagnostic message.",
          "Cannot be overridden via configuration or environment variable."
        ],
        "suggestion": "Accept an optional font path parameter in Renderer::new(), or read from an env var (SPEDIMAGE_FONT_PATH), with the embedded Inter as documented fallback. Add a tracing::info! when falling back.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-07T17:19:29+00:00",
      "last_seen": "2026-03-07T17:19:29+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "rust",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::incomplete_migration::crop_shader_uniforms_unused::0c20c1fa": {
      "id": "review::.::holistic::incomplete_migration::crop_shader_uniforms_unused::0c20c1fa",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "CROP_SHADER defines CropUniforms with x/y/w/h but the fragment shader ignores them entirely",
      "detail": {
        "holistic": true,
        "dimension": "incomplete_migration",
        "related_files": [
          "src/gpu_renderer.rs"
        ],
        "evidence": [
          "CROP_SHADER struct (lines 164-169): `struct CropUniforms { x: f32, y: f32, w: f32, h: f32 }` \u00e2\u20ac\u201d bound at group 0 binding 0.",
          "Fragment shader (lines 185-192): returns `vec4(0.0, 0.0, 0.0, 0.5)` unconditionally \u00e2\u20ac\u201d crop rect values are never read.",
          "The crop pipeline layout is also empty (`push_constant_ranges: &[]`, `bind_group_layouts: &[]` at line 433) \u00e2\u20ac\u201d the CropUniforms binding in the shader is dead."
        ],
        "suggestion": "Either complete the crop overlay shader (use crop rect to darken only the areas outside the crop box) or remove the CropUniforms struct from the WGSL and document that the pipeline uses scissor rects instead.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-07T17:19:29+00:00",
      "last_seen": "2026-03-07T17:19:29+00:00",
      "resolved_at": null,
