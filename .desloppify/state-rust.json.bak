    "review::.::holistic::api_surface_coherence::ui_state_dual_status_api::03e7265d": {
      "id": "review::.::holistic::api_surface_coherence::ui_state_dual_status_api::03e7265d",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "UiState has both a pub status_message field and set_status()/get_status() methods \u00e2\u20ac\u201d two write paths for the same data",
      "detail": {
        "holistic": true,
        "dimension": "api_surface_coherence",
        "related_files": [
          "src/ui.rs"
        ],
        "evidence": [
          "status_message: pub \u00e2\u20ac\u201d callers can assign directly.",
          "set_status(), clear_status(), get_status() methods in UiState impl also exist.",
          "Dual write contract means callers may bypass the method (which could contain additional logic in future) without any compiler warning."
        ],
        "suggestion": "Narrow status_message to pub(crate) or private and enforce all writes via set_status(). This makes the accessor the single, stable contract.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-07T17:19:29+00:00",
